PORT=3000

# Optional: set this to the public website URL in production.
SITE_URL=http://localhost:3000

# Optional PayToday server-side checkout settings.
# Fill these only after confirming the merchant account values.
PAYTODAY_SHOP_KEY=
PAYTODAY_SHOP_HANDLE=
PAYTODAY_PRIVATE_KEY=
PAYTODAY_ENVIRONMENT=production

# Optional: if PayToday gives you a direct server API endpoint for creating intents,
# set it here and the backend will proxy the request server-side.
PAYTODAY_CREATE_INTENT_URL=
